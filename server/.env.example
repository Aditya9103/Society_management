# Server
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/parapet?retryWrites=true&w=majority
PORT=5000
NODE_ENV=development
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d
CLIENT_URL=http://localhost:5173

# Email (Brevo SMTP)
BREVO_SMTP_HOST=smtp-relay.brevo.com
BREVO_SMTP_PORT=587
BREVO_SMTP_USER=
BREVO_SMTP_KEY=
SALES_NOTIFICATION_EMAIL=sales@yourcompany.com
SUPPORT_NOTIFICATION_EMAIL=support@yourcompany.com
FROM_EMAIL=noreply@parapet.io
FROM_NAME=Parapet
